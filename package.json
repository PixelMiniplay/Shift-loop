{
  "name": "shift-loop",
  "private": true,
  "version": "1.0.0",
  "description": "Loop - A hypnotic rhythm-based puzzle game with dimension shifting mechanics",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build && tsc --noEmit",
    "preview": "vite preview",
    "clean": "rm -rf dist node_modules",
    "lint": "tsc --noEmit",
    "type-check": "tsc --noEmit --skipLibCheck",
    "format": "prettier --write src/",
    "test": "vitest"
  },
  "dependencies": {
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "lucide-react": "^0.546.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@tailwindcss/vite": "^4.1.14",
    "tailwindcss": "^4.1.14",
    "autoprefixer": "^10.4.21",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^2.1.8",
    "prettier": "^3.4.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
